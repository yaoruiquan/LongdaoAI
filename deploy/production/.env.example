# =============================================================================
# 龙道 AI 生产环境变量模板（DEP-001 / DEP-002）
# =============================================================================
# 用法：
#   cp .env.example .env
#   然后填写下面所有【必填】项。切勿把真实 .env 提交到 git。
#
# 生成随机密钥（推荐）：openssl rand -hex 32
#
# 本文件只含占位符，不含任何真实密钥。
# =============================================================================

# -----------------------------------------------------------------------------
# 镜像（必填）—— 由 deploy/build_production_image.sh 构建产出
# -----------------------------------------------------------------------------
# 镜像仓库前缀（默认 longdao/sub2api；若用私有 registry 改成完整前缀）
IMAGE_REPO=longdao/sub2api
# 【必填】版本化不可变 tag，禁止 latest。例如首个版本：
IMAGE_TAG=v2026.07.15-1

# -----------------------------------------------------------------------------
# 对外域名与 HTTPS（必填）—— Caddy 用它签发 Let's Encrypt 证书
# -----------------------------------------------------------------------------
# 【必填】解析到本机公网 IP 的域名（80/443 需可从公网访问以完成 ACME 验证）
LONGDAO_DOMAIN=api.longdao.example.com
# Let's Encrypt 注册邮箱（推荐填写，用于证书到期通知；留空也能签发）
LONGDAO_ACME_EMAIL=admin@longdao.example.com

# -----------------------------------------------------------------------------
# 运行模式
# -----------------------------------------------------------------------------
# 生产固定 release / standard；非调试请勿改动
SERVER_MODE=release
RUN_MODE=standard

# -----------------------------------------------------------------------------
# 时区（影响所有时间运算，含“今日”统计边界）
# -----------------------------------------------------------------------------
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# PostgreSQL（POSTGRES_PASSWORD 必填）
# -----------------------------------------------------------------------------
POSTGRES_USER=sub2api
# 【必填】数据库密码
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=sub2api
# 连接池（可用默认）
# DATABASE_MAX_OPEN_CONNS=50
# DATABASE_MAX_IDLE_CONNS=10
# DATABASE_CONN_MAX_LIFETIME_MINUTES=30
# DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

# -----------------------------------------------------------------------------
# Redis（REDIS_PASSWORD 生产必填！）
# -----------------------------------------------------------------------------
# 【必填】生产环境 Redis 必须设置密码。即使 Redis 不暴露公网端口，
# 内部网络内也应启用认证，避免同网段其他容器未授权访问缓存/限流数据。
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
# REDIS_DB=0
# REDIS_POOL_SIZE=1024
# REDIS_MIN_IDLE_CONNS=10
# REDIS_ENABLE_TLS=false

# -----------------------------------------------------------------------------
# 管理员账号（首次运行自动创建，必填）
# -----------------------------------------------------------------------------
# 【必填】管理员登录邮箱
ADMIN_EMAIL=admin@longdao.example.com
# 【必填】管理员初始密码（首次登录后建议修改）
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# -----------------------------------------------------------------------------
# JWT（必填，务必固定）
# -----------------------------------------------------------------------------
# 【必填】固定值，否则容器重启后所有登录态失效。生成：openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
# JWT_EXPIRE_HOUR=24

# -----------------------------------------------------------------------------
# TOTP / 2FA 加密密钥（必填，务必固定）
# -----------------------------------------------------------------------------
# 【必填】固定值，否则重启后所有已配置 2FA 失效。生成：openssl rand -hex 32
TOTP_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# -----------------------------------------------------------------------------
# Gemini OAuth（可选，不用可留空）
# -----------------------------------------------------------------------------
# GEMINI_OAUTH_CLIENT_ID=
# GEMINI_OAUTH_CLIENT_SECRET=
# GEMINI_OAUTH_SCOPES=
# GEMINI_QUOTA_POLICY=
# GEMINI_CLI_OAUTH_CLIENT_SECRET=
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 安全：URL 白名单（可选，默认关闭）
# -----------------------------------------------------------------------------
# SECURITY_URL_ALLOWLIST_ENABLED=false
# SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
# SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false
# SECURITY_URL_ALLOWLIST_UPSTREAM_HOSTS=

# -----------------------------------------------------------------------------
# 在线更新代理（访问 GitHub / 价格数据，可选）
# -----------------------------------------------------------------------------
# UPDATE_PROXY_URL=http://host:port
